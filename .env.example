# sacred-flow: Marabés — Environment Variables
# COPIA este ficheiro para .env e preenche com as tuas keys

# Supabase — Backend / Auth / Database
VITE_SUPABASE_URL=your-supabase-project-url-here
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key-here
VITE_SUPABASE_PROJECT_ID=your-supabase-project-id-here

# CesiumJS Ion Token — OBRIGATÓRIO para Atlas (globo 3D)
VITE_CESIUM_ION_TOKEN=your_cesium_ion_token_here

# ElevenLabs — Voz do Echo-Vox (News)
VITE_ELEVENLABS_API_KEY=your_elevenlabs_key_here

# Real-time Data APIs
VITE_CLIMATE_API_KEY=your_climate_api_key
VITE_ECONOMY_API_KEY=your_economy_api_key

# Grok Defense
VITE_GROK_HONEYPOT_ENABLED=true

# CrowdSec + Fail2Ban (backend)
CROWDSEC_API_KEY=your_crowdsec_key
FAIL2BAN_ENABLED=true
