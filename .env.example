# ═══════════════════════════════════════════════════════════════════════════
# ETERNAL NEXUS — ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual keys/tokens
# Never commit .env to version control!
#
# Sacred Flow: Tribunal → Atlas → Index → News → Streams
# ═══════════════════════════════════════════════════════════════════════════

# ═══ CESIUM (REQUIRED for Atlas real terrain) ═══
# Get free token at: https://ion.cesium.com/tokens
# Free tier: 5GB/month imagery + terrain
VITE_CESIUM_ION_TOKEN=your_cesium_ion_token_here

# ═══ SUPABASE (REQUIRED for database) ═══
# Get from your Supabase project settings
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ═══ WEATHER DATA (Optional - Atlas will use mock data if missing) ═══
# OpenWeatherMap API - Free tier: 1,000 calls/day
# Get key at: https://openweathermap.org/api
VITE_OPENWEATHER_API_KEY=your_openweather_api_key_here

# ═══ POLLUTION DATA (Optional) ═══
# WAQI (World Air Quality Index) - Free token
# Get token at: https://aqicn.org/api/
VITE_WAQI_API_TOKEN=your_waqi_token_here

# ═══ AI SERVICES (For News organ - Echo-Vox) ═══
# ElevenLabs - Text-to-Speech
# Get key at: https://elevenlabs.io/
VITE_ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# OpenAI - GPT models (for Zeta-9, Kronos agents)
# Get key at: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude - For advanced reasoning (optional)
# Get key at: https://console.anthropic.com/
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Gemini - For data processing (Sora-Prime, Cidance)
# Get key at: https://ai.google.dev/
VITE_GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# ═══ MEDIA GENERATION (Optional - for demos) ═══
# Runway ML - Video generation (ClipMaster)
# Get key at: https://runwayml.com/
VITE_RUNWAY_API_KEY=your_runway_api_key_here

# Replicate - Image/video models
# Get token at: https://replicate.com/account/api-tokens
VITE_REPLICATE_API_TOKEN=your_replicate_token_here

# ═══ STREAMING PLATFORMS (For Index broadcasts) ═══
# YouTube Data API v3
# Get key at: https://console.cloud.google.com/apis/credentials
VITE_YOUTUBE_API_KEY=your_youtube_api_key_here

# Twitch API
# Get client ID/secret at: https://dev.twitch.tv/console/apps
VITE_TWITCH_CLIENT_ID=your_twitch_client_id_here
VITE_TWITCH_CLIENT_SECRET=your_twitch_client_secret_here

# ═══ SECURITY (Production) ═══
# CrowdSec API - DDoS protection
# Get key at: https://app.crowdsec.net/
VITE_CROWDSEC_API_KEY=your_crowdsec_api_key_here

# Cloudflare Analytics
# Get from Cloudflare dashboard
VITE_CF_ANALYTICS_TOKEN=your_cloudflare_analytics_token_here

# ═══ GEOPOLITICAL DATA (Optional) ═══
# ACLED (Armed Conflict Location & Event Data Project)
# Get key at: https://acleddata.com/register/
VITE_ACLED_API_KEY=your_acled_api_key_here

# World Bank API (usually no key required)
# Docs: https://datahelpdesk.worldbank.org/knowledgebase/topics/125589
VITE_WORLDBANK_API_KEY=optional_worldbank_key

# ═══ DEVELOPMENT ═══
# Environment mode
NODE_ENV=development

# Vite dev server port
VITE_PORT=5173

# Enable debug logging
VITE_DEBUG=false

# ═══════════════════════════════════════════════════════════════════════════
# NOTES:
#
# REQUIRED for basic functionality:
# - VITE_CESIUM_ION_TOKEN (Atlas won't render without this)
# - VITE_SUPABASE_URL + VITE_SUPABASE_ANON_KEY (database access)
#
# OPTIONAL but recommended:
# - VITE_OPENWEATHER_API_KEY (real weather data in Atlas)
# - VITE_WAQI_API_TOKEN (real pollution data)
# - VITE_ELEVENLABS_API_KEY (Echo-Vox voice synthesis)
#
# ALL OTHER KEYS:
# - Nice to have for full feature set
# - System will gracefully degrade without them
# - Mock data will be used where applicable
#
# SECURITY:
# - Never commit .env to git (already in .gitignore)
